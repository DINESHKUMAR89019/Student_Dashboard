# Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# MongoDB Connection String
# Get this from MongoDB Atlas or your local MongoDB instance
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/student-tracker?retryWrites=true&w=majority

# Example for local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/student-tracker

# Optional: API Base URL (for production)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Enable debug logging
DEBUG=false

# Security Notes:
# - NEVER commit .env.local to version control
# - Add .env.local to .gitignore
# - Use different credentials for development and production
# - Rotate credentials regularly
